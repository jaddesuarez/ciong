---
import { ACCORDION_ITEMS } from "@/consts/index";
---

<section class="relative py-[100px] px-[80px]">
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/section-bg.jpeg" 
      alt="Background" 
      class="w-full h-full object-cover opacity-60"
    />
    <div class="absolute inset-0 bg-purple/40"></div>
  </div>
  
  <div class="relative z-10 flex flex-col items-center justify-center">
    <div class="flex flex-col items-center mb-20">
      <h1 class="text-display-heavy text-beige uppercase">Cualidades</h1>
      <h1 class="text-display-heavy text-yellow uppercase">Para ser amado</h1>
    </div>

    <div class="w-full">
    {ACCORDION_ITEMS.map((item, index) => (
        <div class="text-beige">
          <hr class="border-beige/70" />
          <button
            class="py-5 accordion-trigger w-full text-left text-xxl-heavy flex justify-between items-center uppercase"
            aria-expanded="false"
            aria-controls={`accordion-${index}`}
          >
            {item.title}
            <img 
              src="/svg/arrow-down.svg" 
              alt="Toggle" 
              class="w-6 h-6 transition-transform duration-200 accordion-icon"
            />
          </button>
          <div
            id={`accordion-${index}`}
            class="accordion-content hidden pb-4 max-w-[1000px]"
          >
            <p class="text-l-regular">{item.content}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.accordion-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const content = trigger.nextElementSibling;
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      const icon = trigger.querySelector('.accordion-icon') as HTMLImageElement;
      
      // Close all other accordions
      document.querySelectorAll('.accordion-trigger').forEach((t) => {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          t.nextElementSibling?.classList.add('hidden');
          const otherIcon = t.querySelector('.accordion-icon') as HTMLImageElement;
          if (otherIcon) otherIcon.src = '/svg/arrow-down.svg';
        }
      });

      // Toggle current accordion
      trigger.setAttribute('aria-expanded', (!isExpanded).toString());
      content?.classList.toggle('hidden');
      if (icon) {
        icon.src = isExpanded ? '/svg/arrow-down.svg' : '/svg/arrow-up.svg';
      }
    });
  });
</script>
