---
import "./WhatIsFriendship.styles.css"
import Frame from "../Frame/Frame.astro"
import { FRIENDSHIP_IMAGES } from "@/consts/index"
---

<section id="what-is-friendship" class="what-is-friendship">
  <div class="what-is-friendship-content">
    <div class="flex flex-col items-center">
      <h2
        class="text-xxl-heavy md:text-display-heavy text-black uppercase flex flex-col text-center"
      >
        <span class="text-black">Qué es la</span>
        <span class="text-purple">Amistad</span>
      </h2>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 lg:grid-rows-2 gap-8 md:gap-16"
    >
      {
        FRIENDSHIP_IMAGES.map(
          ({ rotation, frameWidth, frameHeight, imgWidth, imgHeight, image, text, element, bg }) => (
            <Frame
              className="lg:hover:scale-105 transition-transform duration-300"
              dimensions={{
                frameWidth,
                frameHeight,
              }}
              rotation={rotation}
              bg={bg}
            >
              <img src={image} alt={text} class={`${imgWidth} ${imgHeight} object-cover`} />
              <div class="mt-3 mx-auto" set:html={element} />
            </Frame>
          )
        )
      }
    </div>
    <a
      href="/test-amistad" 
      class="inline-block px-8 sm:px-[60px] py-4 sm:py-[20px] rounded-full border-2 border-purple text-purple text-l-bold sm:text-xl-bold hover:bg-purple hover:text-white transition-colors duration-300"
    >
      Test de amistad
    </a>
  </div>
</section>
