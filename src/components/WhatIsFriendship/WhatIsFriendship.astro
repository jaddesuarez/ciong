---
import "./WhatIsFriendship.styles.css"
import Frame from "../Frame/Frame.astro"
import { FRIENDSHIP_IMAGES } from "@/consts/index"
---

<section id="what-is-friendship" class="what-is-friendship">
  <div class="what-is-friendship-content">
    <div class="flex flex-col items-center">
      <h1 class="text-display-heavy text-black uppercase">Qué es la</h1>
      <h1 class="text-display-heavy text-purple uppercase">Amistad</h1>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 lg:grid-rows-2 gap-8 md:gap-16"
    >
      {
        FRIENDSHIP_IMAGES.map(
          ({ rotation, width, height, image, text, element }) => (
            <Frame
              className="hover:scale-105 transition-transform duration-300"
              dimensions={{
                width,
                height,
              }}
              rotation={rotation}
            >
              <img src={image} alt={text} class="w-full object-cover" />
              <div class="mt-3 mx-auto" set:html={element} />
            </Frame>
          )
        )
      }
    </div>
    <a
      href="https://example.com/test-amistad"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-[60px] py-[20px] rounded-full border-2 border-purple text-purple text-xl-bold hover:bg-purple hover:text-white transition-colors duration-300"
    >
      Test de amistad
    </a>
  </div>
</section>
