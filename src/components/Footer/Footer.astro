---
import "./Footer.styles.css"
---

<footer class="px-20 py-10 mt-auto bg-yellow">
  <div class="">
    <div class="flex justify-between">
      <div>
        <h1 class="text-xxl-heavy text-black">OTRAS WEBS DE CI</h1>
        <ul class="flex flex-col gap-1 mt-5">
          <li class="text-m-regular text-black underline uppercase">
            <a href="https://livingforothers.ciong.org/">Dignidad</a>
          </li>
          <li class="text-m-regular text-black underline uppercase">
            <a href="https://esoquenosune.ciong.org/">Eso que nos une</a>
          </li>
          <li class="text-m-regular text-black underline uppercase">
            <a href="https://preguntas.ciong.org/">Preguntas incómodas</a>
          </li>
          <li class="text-m-regular text-black underline uppercase">
            <a href="https://www.youtube.com/watch?v=WDWS-KCK2ZA">Sé más tú</a>
          </li>
          <li class="text-m-regular text-black underline uppercase">
            <a href="https://valelapena.ciong.org/">Vale la pena</a>
          </li>
          <li class="text-m-regular text-black underline uppercase">
            <a href="https://miedo.ciong.org/">No te tengas miedo</a>
          </li>
        </ul>
      </div>
      <div>
        <h1 class="text-xxl-heavy text-black uppercase">Otras campañas</h1>
      </div>
      <div>
        <h1 class="text-xxl-heavy text-black uppercase">Síguenos</h1>
        <ul class="flex flex-col gap-1 mt-5">
          <li class="text-m-regular text-black uppercase">
            <a href="https://ciong.org/" class="flex items-center gap-2">
              <img src="/website-icon.svg" alt="Website" class="w-5 h-5" />
              <span>Website</span>
            </a>
          </li>
          <li class="text-m-regular text-black uppercase">
            <a
              href="https://www.instagram.com/cooperacion_internacional_ong/"
              class="flex items-center gap-2"
            >
              <img src="/instagram-icon.svg" alt="Instagram" class="w-5 h-5" />
              <span>Instagram</span>
            </a>
          </li>
          <li class="text-m-regular text-black uppercase">
            <a
              href="https://www.tiktok.com/@cooperacion_int_ong"
              class="flex items-center gap-2"
            >
              <img src="/tiktok-icon.svg" alt="TikTok" class="w-5 h-5" />
              <span>TikTok</span>
            </a>
          </li>
          <li class="text-m-regular text-black uppercase">
            <a
              href="https://www.youtube.com/@JuventudSolidaria"
              class="flex items-center gap-2"
            >
              <img src="/youtube-icon.svg" alt="YouTube" class="w-5 h-5" />
              <span>YouTube</span>
            </a>
          </li>
          <li class="text-m-regular text-black uppercase">
            <a href="https://x.com/cooperacion" class="flex items-center gap-2">
              <img src="/x-icon.svg" alt="X" class="w-5 h-5" />
              <span>X</span>
            </a>
          </li>
          <li class="text-m-regular text-black uppercase">
            <a
              href="https://www.linkedin.com/company/893242/admin/page-posts/published/"
              class="flex items-center gap-2"
            >
              <img src="/linkedin-icon.svg" alt="LinkedIn" class="w-5 h-5" />
              <span>LinkedIn</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="flex gap-8 my-10">
      <img src="/COING-logo.svg" alt="CIONG" />
      <img src="/COING-logo.svg" alt="CIONG" />
      <img src="/COING-logo.svg" alt="CIONG" />
    </div>
  </div>
</footer>

