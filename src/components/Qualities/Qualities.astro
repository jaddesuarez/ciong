---
import "./Qualities.styles.css"
import { ACCORDION_ITEMS } from "@/consts/index"
---

<section
  id="qualities"
  class="qualities py-[60px] px-5 md:py-10 md:px-10 lg:py-[100px] lg:px-[80px]"
>
  <div class="flex flex-col items-center justify-center w-full">
    <div class="flex flex-col items-center mb-10 md:mb-20">
      <h1 class="text-xxxl-heavy md:text-display-heavy text-beige uppercase">
        Cualidades
      </h1>
      <h1 class="text-xxxl-heavy md:text-display-heavy text-yellow uppercase">
        Para ser amado
      </h1>
    </div>

    <div class="w-full">
      {
        ACCORDION_ITEMS.map((item, index) => (
          <div class="flex flex-col text-beige border-t border-beige py-[30px] md:py-[26px]">
            <button
              class="accordion-trigger w-full text-left text-l-bold md:text-xxl-heavy flex justify-between items-center uppercase cursor-pointer"
              aria-expanded="false"
              aria-controls={`accordion-${index}`}
            >
              {item.title}
              <img
                src="/svg/arrow-down.svg"
                alt="Toggle"
                class="w-6 h-6 transition-transform duration-300 ease-out"
              />
            </button>
            <div
              id={`accordion-${index}`}
              class="grid grid-rows-[0fr] opacity-0 mt-0 transition-[grid-template-rows,opacity,margin-top] duration-300 ease-out"
            >
              <p class="text-s-regular text-left md:text-l-regular overflow-hidden">
                {item.content}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[aria-controls]").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const content = trigger.nextElementSibling
      const isExpanded = trigger.getAttribute("aria-expanded") === "true"
      const icon = trigger.querySelector("img")
      // Close all other accordions
      document.querySelectorAll("[aria-controls]").forEach((t) => {
        if (t !== trigger) {
          t.setAttribute("aria-expanded", "false")
          t.nextElementSibling?.classList.remove(
            "grid-rows-[1fr]",
            "opacity-100",
            "pb-[30px]",
            "mt-[10px]"
          )
          t.nextElementSibling?.classList.add(
            "grid-rows-[0fr]",
            "opacity-0",
            "mt-0"
          )
          const otherIcon = t.querySelector("img")
          if (otherIcon) {
            otherIcon.classList.remove("rotate-180")
            otherIcon.src = "/svg/arrow-down.svg"
          }
        }
      })

      // Toggle current accordion
      trigger.setAttribute("aria-expanded", (!isExpanded).toString())
      if (content) {
        if (!isExpanded) {
          content.classList.remove("grid-rows-[0fr]", "opacity-0", "mt-0")
          content.classList.add("grid-rows-[1fr]", "opacity-100", "mt-[10px]")
          if (icon) {
            icon.classList.add("rotate-180")
          }
        } else {
          content.classList.remove(
            "grid-rows-[1fr]",
            "opacity-100",
            "mt-[10px]"
          )
          content.classList.add("grid-rows-[0fr]", "opacity-0", "mt-0")
          if (icon) {
            icon.classList.remove("rotate-180")
            icon.src = "/svg/arrow-down.svg"
          }
        }
      }
    })
  })
</script>
