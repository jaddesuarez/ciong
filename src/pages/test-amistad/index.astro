---
import Layout from "@/layouts/Layout.astro"
import { FRIENDSHIP_TEST } from "@/consts/index"
import Frame from "@/components/Frame/Frame.astro"
---

<Layout>
  <main class="py-[50px] px-5 md:px-20">
    <a 
      href="/" 
      class="flex items-center gap-2 text-purple hover:text-purple/80 transition-colors mb-10"
    >
      <svg 
        width="24" 
        height="24" 
        viewBox="0 0 24 24" 
        fill="none" 
        xmlns="http://www.w3.org/2000/svg"
        class="rotate-180"
      >
        <path 
          d="M5 12H19M19 12L12 5M19 12L12 19" 
          stroke="currentColor" 
          stroke-width="2" 
          stroke-linecap="round" 
          stroke-linejoin="round"
        />
      </svg>
      <span class="text-l-bold">Volver a la home</span>
    </a>

    <div id="testContainer">
      <h1 class="text-xxl-heavy text-purple uppercase text-center mb-10">
        Test de la Amistad
      </h1>

      <form id="friendshipTest" class="max-w-3xl mx-auto">
        {FRIENDSHIP_TEST.map((question) => (
          <div class="mb-8 p-6 bg-white rounded-lg shadow-md">
            <p class="text-m-bold-small md:text-l-bold mb-4">
              {question.id}. {question.question}
            </p>
            <div class="space-y-3">
              {question.options.map((option) => (
                <label class="flex items-center space-x-3 cursor-pointer">
                  <input
                    type="radio"
                    name={`question-${question.id}`}
                    value={option.value}
                    required
                    class="form-radio h-5 w-5 text-purple cursor-pointer"
                  />
                  <span class="text-s-medium md:text-m-regular cursor-pointer">{option.text}</span>
                </label>
              ))}
            </div>
          </div>
        ))}

        <button
          type="submit"
          class="w-full py-3 md:py-4 bg-purple text-white text-m-bold md:text-l-bold rounded-full hover:bg-purple/90 transition-colors cursor-pointer"
        >
          Ver Resultado
        </button>
      </form>
    </div>

    <div 
      id="testResults" 
      class="hidden w-full h-full flex-col lg:flex-row items-center justify-center py-10 md:py-20"
    >
      <Frame 
        dimensions={{ width: "w-[300px] md:w-[500px]", height: "h-[200px] md:h-[400px]" }}
        bg="bg-yellow"
        padding={{ top: "pt-3", bottom: "pb-2", lateral: "px-3" }}
        rotation={-2.74}
      >
        <img
            id="friendship-image"
            class="w-[300px] h-[170px] md:w-[470px] md:h-[360px] object-cover"
            src=''
            alt="Friendship illustration"
          />
      </Frame>
      <div class="flex flex-col items-start justify-items-start lg:w-1/3 mx-10 my-10">
        <h2 class="text-large-heavy md:text-xxxl-heavy text-black uppercase">Amistad</h2>
        <h2 id="resultTitle" class="text-large-heavy md:text-xxxl-heavy text-purple mb-4 uppercase"></h2>
        <p class="text-l-regular" id="resultDescription"></p>
      </div>
    </div>
  </main>
</Layout>

<script>
  function handleSubmit(e: Event) {
    e.preventDefault();
    
    const form = e.target as HTMLFormElement;
    const testContainer = document.getElementById('testContainer');
    const resultsDiv = document.getElementById('testResults');
    const resultTitle = document.getElementById('resultTitle');
    const resultDescription = document.getElementById('resultDescription');
    const friendshipImage = document.getElementById('friendship-image') as HTMLImageElement;
    if (!form || !resultsDiv || !resultTitle || !resultDescription || !testContainer) return;
    
    const formData = new FormData(form);
    const answers = Array.from(formData.values());
    
    const counts: Record<string, number> = {
      'A': 0,
      'B': 0,
      'C': 0,
      'D': 0
    };
    
    answers.forEach((answer) => {
      if (typeof answer === 'string') {
        counts[answer]++;
      }
    });

    let maxCount = 0;
    let mostCommon = 'A';
    
    Object.entries(counts).forEach(([answer, count]) => {
      if (count > maxCount) {
        maxCount = count;
        mostCommon = answer;
      }
    });

    const results = {
      'A': {
        title: "Profunda y Madura",
        description: "Tienes una amistad sólida, basada en la confianza, la honestidad y el apoyo mutuo. Eres un amigo atento, capaz de resolver conflictos y compartir tanto los buenos como los malos momentos. Valoras la amistad como un vínculo importante y te esfuerzas por mantenerla a lo largo del tiempo.",
        img: "/images/hero/img03.png"
      },
      'B': {
        title: "Cercana en Desarrollo",
        description: "Tus amistades son significativas y tienes una buena base para relaciones profundas, aunque puede que algunas áreas necesiten más atención. Quizás a veces te cuesta abrirte por completo o gestionar conflictos, pero te esfuerzas en ser un buen amigo. Estás en el camino de fortalecer aún más estas relaciones.",
        img: "/images/TypesOfFriendShip/img02.png"
      },
      'C': {
        title: "Superficial o en Construcción",
        description: "Aunque tienes buenas intenciones, puede que tus amistades sean más superficiales o que aún no estén completamente consolidadas. Podrías trabajar en aspectos como la comunicación abierta, la empatía o la resolución de conflictos para construir relaciones más sólidas y significativas.",
        img: "/images/hero/img01.png"
      },
      'D': {
        title: "Distante o en Riesgo",
        description: "Es posible que tus relaciones de amistad sean un poco distantes o estén en una etapa difícil. Puede que evites temas profundos o no priorices resolver conflictos. Esto podría ser por desinterés o por falta de tiempo. Reflexionar sobre la importancia de la amistad y cómo fortalecerla podría ayudarte a mejorar estas relaciones.",
        img: "/images/TypesOfFriendShip/img08.png"
      }
    };

    const result = results[mostCommon as keyof typeof results];
    
    if (result) {
      resultTitle.textContent = result.title;
      resultDescription.textContent = result.description;
      testContainer.classList.add('hidden');
      resultsDiv.classList.remove('hidden');
      resultsDiv.classList.add('flex');
      resultsDiv.scrollIntoView({ behavior: 'smooth' });
      if (friendshipImage) {
        friendshipImage.src = result.img;
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('friendshipTest');
    if (form) {
      form.addEventListener('submit', handleSubmit);
    }
  });
</script>
